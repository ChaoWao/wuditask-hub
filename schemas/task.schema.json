{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:wuditask:schema:task:v1",
  "title": "WudiTask task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "title",
    "repo",
    "created_by",
    "owner",
    "priority",
    "created_at",
    "goal",
    "context",
    "acceptance_criteria",
    "dependencies",
    "claim",
    "links"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^WDT-[0-9]{8}T[0-9]{6}Z-[0-9A-F]{6}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "repo": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
    },
    "created_by": {
      "$ref": "#/$defs/identity"
    },
    "owner": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/identity"
        }
      ]
    },
    "priority": {
      "enum": ["P0", "P1", "P2", "P3"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "Z$"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/acceptanceCriterion"
      }
    },
    "dependencies": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^WDT-[0-9]{8}T[0-9]{6}Z-[0-9A-F]{6}$"
      }
    },
    "claim": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/claim"
        }
      ]
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "completion": {
      "$ref": "#/$defs/completion"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "owner": {
            "type": "null"
          }
        }
      },
      "then": {
        "properties": {
          "claim": {
            "type": "null"
          }
        }
      },
      "else": {
        "properties": {
          "claim": {
            "$ref": "#/$defs/claim"
          }
        }
      }
    }
  ],
  "$defs": {
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["login", "github_id"],
      "properties": {
        "login": {
          "type": "string",
          "minLength": 1
        },
        "github_id": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "acceptanceCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "verification"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^AC-[1-9][0-9]*$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "verification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "value"],
          "properties": {
            "type": {
              "enum": ["command", "file", "manual", "url"]
            },
            "value": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["token", "github_login", "github_id", "claimed_at"],
      "properties": {
        "token": {
          "type": "string",
          "minLength": 1
        },
        "github_login": {
          "type": "string",
          "minLength": 1
        },
        "github_id": {
          "type": "integer",
          "minimum": 1
        },
        "claimed_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        }
      }
    },
    "completion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outcome",
        "completed_at",
        "completed_by",
        "result",
        "acceptance_results"
      ],
      "properties": {
        "outcome": {
          "enum": ["done", "failed", "cancelled"]
        },
        "completed_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "Z$"
        },
        "completed_by": {
          "$ref": "#/$defs/identity"
        },
        "result": {
          "type": "string",
          "minLength": 1
        },
        "acceptance_results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["criterion_id", "status", "evidence"],
            "properties": {
              "criterion_id": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "enum": ["passed", "failed", "skipped"]
              },
              "evidence": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
